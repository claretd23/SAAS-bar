+          )}
+        </div>
+      )}
+
+      <div style={{ display: "flex", justifyContent: "space-between", fontWeight: 600, marginBottom: 14 }}>
+        <span>Total a cobrar</span>
+        <span style={{ color: C.neon, fontSize: 16 }}>{fmt(selectedTotal)}</span>
+      </div>
+
+      <div style={{ display: "flex", gap: 8 }}>
+        <Btn variant="ghost" onClick={onClose} style={{ flex: 1 }}>Cancelar</Btn>
+        <Btn variant="primary" onClick={confirmPay} disabled={saving} style={{ flex: 1 }}>
+          {saving ? "Cobrando..." : "Confirmar pago"}
+        </Btn>
+      </div>
+    </Modal>
+  );
+}
