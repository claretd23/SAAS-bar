+            border: `1px solid ${pay === m.id ? C.neon2 : C.border}`,
+            color: pay === m.id ? C.neon2 : C.muted, cursor: "pointer",
+            display: "flex", flexDirection: "column", alignItems: "center", gap: 4,
+          }}>
+            <Icon name={m.icon} size={16} color={pay === m.id ? C.neon2 : C.muted} />
+            {m.label}
+          </button>
+        ))}
+      </div>
