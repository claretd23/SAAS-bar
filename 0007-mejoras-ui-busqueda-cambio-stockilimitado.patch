new file mode 100644
index 0000000..1d1196e
--- /dev/null
+++ b/backend/diagnostico.js
@@ -0,0 +1,35 @@
+import Database from "better-sqlite3";
+import { fileURLToPath } from "url";
+import path from "path";
+
+const __dirname = path.dirname(fileURLToPath(import.meta.url));
+const db = new Database(path.join(__dirname, "barpos.db"));
+
+console.log("=== foreign_keys actual ===");
+console.log(db.pragma("foreign_keys", { simple: true }));
+
+console.log("\n=== Todas las tablas ===");
+console.log(db.prepare("SELECT name FROM sqlite_master WHERE type='table'").all());
+
+console.log("\n=== foreign_key_list de TODAS las tablas (buscamos quién referencia a orders) ===");
+const tables = db.prepare("SELECT name FROM sqlite_master WHERE type='table'").all();
+for (const t of tables) {
+  const fks = db.prepare(`PRAGMA foreign_key_list(${t.name})`).all();
+  if (fks.length) {
+    console.log(`Tabla ${t.name}:`, fks);
+  }
+}
+
+console.log("\n=== foreign_key_check (filas que YA rompen alguna FK ahora mismo) ===");
+console.log(db.prepare("PRAGMA foreign_key_check").all());
+
+console.log("\n=== Columnas actuales de orders ===");
+console.log(db.prepare("PRAGMA table_info(orders)").all().map(c => c.name));
+
+console.log("\n=== Filas en payments ===");
+console.log(db.prepare("SELECT id, order_id FROM payments").all());
+
+console.log("\n=== sqlite_master de orders_new si existe ===");
+console.log(db.prepare("SELECT name, sql FROM sqlite_master WHERE name='orders_new'").all());
+
+db.close();
diff --git a/backend/reset-orders.js b/backend/reset-orders.js
new file mode 100644
index 0000000..27f4c10
--- /dev/null
+++ b/backend/reset-orders.js
@@ -0,0 +1,20 @@
+import Database from "better-sqlite3";
+import { fileURLToPath } from "url";
+import path from "path";
+import fs from "fs";
+
+const __dirname = path.dirname(fileURLToPath(import.meta.url));
+const dbPath = path.join(__dirname, "barpos.db");
+const db = new Database(dbPath);
+
+// Borra TODO el contenido de orders y payments (y la tabla orders_new
+// residual si quedo de algun intento anterior), dejando intactos
+// businesses, users, products y promos.
+db.exec("DROP TABLE IF EXISTS orders_new");
+db.exec("DELETE FROM payments");
+db.exec("DELETE FROM orders");
+
+console.log("Listo: orders y payments vaciados. businesses, users, products y promos quedaron intactos.");
+console.log("Ahora puedes levantar el backend normalmente (node server.js o npm run dev).");
+
+db.close();
diff --git a/backend/routes/businesses.js b/backend/routes/businesses.js
index bb16eca..3ce0553 100644
--- a/backend/routes/businesses.js
+++ b/backend/routes/businesses.js
@@ -100,4 +100,23 @@ router.delete("/:id/users/:userId", ownBusinessOrSuperadmin, (req, res) => {
   res.json({ ok: true });
 });
 
+// Configuración del negocio: número de mesas y bancos de barra.
+// El admin puede cambiar esto para adaptarlo a su local físico.
+router.get("/:id/config", ownBusinessOrSuperadmin, (req, res) => {
+  const biz = db.prepare("SELECT mesa_count, barra_count FROM businesses WHERE id = ?").get(req.params.id);
+  if (!biz) return res.status(404).json({ error: "Negocio no encontrado" });
+  res.json(biz);
+});
+
+router.patch("/:id/config", ownBusinessOrSuperadmin, (req, res) => {
+  const { mesa_count, barra_count } = req.body;
+  if (mesa_count != null && (mesa_count < 1 || mesa_count > 50)) return res.status(400).json({ error: "El número de mesas debe estar entre 1 y 50" });
+  if (barra_count != null && (barra_count < 0 || barra_count > 20)) return res.status(400).json({ error: "El número de bancos debe estar entre 0 y 20" });
+  const biz = db.prepare("SELECT * FROM businesses WHERE id = ?").get(req.params.id);
+  if (!biz) return res.status(404).json({ error: "Negocio no encontrado" });
+  db.prepare("UPDATE businesses SET mesa_count = ?, barra_count = ? WHERE id = ?")
+    .run(mesa_count ?? biz.mesa_count, barra_count ?? biz.barra_count, req.params.id);
+  res.json({ ok: true });
+});
+
 export default router;
