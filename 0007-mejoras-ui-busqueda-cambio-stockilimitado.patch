 }
 
+const bizCols = db.prepare("PRAGMA table_info(businesses)").all().map(c => c.name);
+if (!bizCols.includes("mesa_count")) {
+  db.exec("ALTER TABLE businesses ADD COLUMN mesa_count INTEGER NOT NULL DEFAULT 10");
